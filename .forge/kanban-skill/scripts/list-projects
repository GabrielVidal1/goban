#!/usr/bin/env bash
# list-projects
# Lists all projects in the kanban/ directory with column and ticket counts.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_common.sh"

if [[ ! -d "$KANBAN_DIR" ]]; then
  echo "Error: kanban directory not found at '$KANBAN_DIR'" >&2; exit 1
fi

printf "%-25s %-10s %s\n" "PROJECT" "COLUMNS" "TICKETS"
printf "%s\n" "$(printf '─%.0s' {1..45})"

while IFS= read -r p; do
  proj_dir="$KANBAN_DIR/$p"
  cols=0 tickets=0
  for col_dir in "$proj_dir"/*/; do
    [[ -d "$col_dir" ]] || continue
    bname="$(basename "$col_dir")"
    [[ "$bname" == _* ]] && continue
    ((cols++))
    count=$(find "$col_dir" -maxdepth 1 -name "*.md" | wc -l | tr -d ' ')
    ((tickets += count))
  done
  printf "%-25s %-10s %s\n" "$p" "$cols" "$tickets"
done < <(list_projects)
