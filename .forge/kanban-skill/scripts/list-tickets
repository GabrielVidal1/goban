#!/usr/bin/env bash
# list-tickets [--project <n>] [--all] [--column <c>] [--assignee <a>] [--priority <p>] [--tag <t>]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_common.sh"

PROJECT_ARG=""
LIST_ALL=0
FILTER_COLUMN=""
FILTER_ASSIGNEE=""
FILTER_PRIORITY=""
FILTER_TAG=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --project)  PROJECT_ARG="$2";  shift 2 ;;
    --all)      LIST_ALL=1;        shift ;;
    --column)   FILTER_COLUMN="$2";   shift 2 ;;
    --assignee) FILTER_ASSIGNEE="$2"; shift 2 ;;
    --priority) FILTER_PRIORITY="$2"; shift 2 ;;
    --tag)      FILTER_TAG="$2";      shift 2 ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

print_tickets() {
  local proj_dir="$1" proj_name="$2"
  printf "%-15s %-20s %-30s %-8s %-12s %-12s %s\n" \
    "PROJECT" "COLUMN" "TITLE" "PRIORITY" "ASSIGNEE" "DUE" "TAGS"
  printf "%s\n" "$(printf '─%.0s' {1..105})"
  for col_dir in "$proj_dir"/*/; do
    [[ -d "$col_dir" ]] || continue
    col_name="$(basename "$col_dir")"
    [[ "$col_name" == _* ]] && continue
    [[ -n "$FILTER_COLUMN" && "${col_name,,}" != "${FILTER_COLUMN,,}" ]] && continue
    for ticket_file in "$col_dir"*.md; do
      [[ -f "$ticket_file" ]] || continue
      title=$(extract_field "$ticket_file" "title")
      priority=$(extract_field "$ticket_file" "priority")
      assignee=$(extract_field "$ticket_file" "assignee")
      due=$(extract_field "$ticket_file" "due")
      tags=$(extract_field "$ticket_file" "tags")
      [[ -n "$FILTER_ASSIGNEE" && "${assignee,,}" != "${FILTER_ASSIGNEE,,}" ]] && continue
      [[ -n "$FILTER_PRIORITY" && "${priority,,}" != "${FILTER_PRIORITY,,}" ]] && continue
      if [[ -n "$FILTER_TAG" ]]; then
        echo "$tags" | grep -qi "$FILTER_TAG" || continue
      fi
      title="${title:-$(basename "$ticket_file" .md)}"
      printf "%-15s %-20s %-30s %-8s %-12s %-12s %s\n" \
        "${proj_name:0:14}" "${col_name:0:19}" "${title:0:29}" \
        "${priority:0:7}" "${assignee:0:11}" "${due:0:11}" "$tags"
    done
  done
}

if [[ $LIST_ALL -eq 1 ]]; then
  mapfile -t ALL_PROJECTS < <(list_projects)
  for p in "${ALL_PROJECTS[@]}"; do
    echo "=== $p ==="
    print_tickets "$KANBAN_DIR/$p" "$p"
    echo ""
  done
  exit 0
fi

resolve_project
print_tickets "$PROJECT_DIR" "$PROJECT_NAME"
