#!/usr/bin/env bash
# new-ticket --project <n> --column <col> --title <title> [--priority <p>] [--assignee <a>] [--due <d>] [--tags <t>] [--body <text>]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_common.sh"

PROJECT_ARG=""
COLUMN="" TITLE="" PRIORITY="" ASSIGNEE="" DUE="" TAGS="" BODY=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --project)  PROJECT_ARG="$2"; shift 2 ;;
    --column)   COLUMN="$2";   shift 2 ;;
    --title)    TITLE="$2";    shift 2 ;;
    --priority) PRIORITY="$2"; shift 2 ;;
    --assignee) ASSIGNEE="$2"; shift 2 ;;
    --due)      DUE="$2";      shift 2 ;;
    --tags)     TAGS="$2";     shift 2 ;;
    --body)     BODY="$2";     shift 2 ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

if [[ -z "$COLUMN" || -z "$TITLE" ]]; then
  echo "Usage: new-ticket --column <col> --title <title> [--project <n>] [options]" >&2; exit 1
fi

resolve_project

TARGET_DIR="$PROJECT_DIR/$COLUMN"
mkdir -p "$TARGET_DIR"

SLUG=$(echo "$TITLE" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g;s/^-//;s/-$//')
FILENAME="${SLUG}-$(date +%Y%m%d%H%M%S).md"
FILEPATH="$TARGET_DIR/$FILENAME"

{
  echo "---"
  echo "title: $TITLE"
  [[ -n "$PRIORITY" ]]  && echo "priority: $PRIORITY"
  [[ -n "$ASSIGNEE" ]]  && echo "assignee: $ASSIGNEE"
  [[ -n "$DUE" ]]       && echo "due: $DUE"
  [[ -n "$TAGS" ]]      && echo "tags: [$TAGS]"
  echo "created: $(date +%Y-%m-%d)"
  echo "---"
  echo ""
  echo "${BODY:-<!-- Add description here -->}"
} > "$FILEPATH"

echo "Created: $FILEPATH"
