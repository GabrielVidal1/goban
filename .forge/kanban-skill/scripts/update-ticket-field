#!/usr/bin/env bash
# update-ticket-field <slug> <field> <value> [--project <n>]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_common.sh"

PROJECT_ARG=""
POSITIONAL=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --project) PROJECT_ARG="$2"; shift 2 ;;
    *) POSITIONAL+=("$1"); shift ;;
  esac
done

if [[ ${#POSITIONAL[@]} -lt 3 ]]; then
  echo "Usage: update-ticket-field <slug> <field> <value> [--project <n>]" >&2; exit 1
fi

QUERY="${POSITIONAL[0]}"
FIELD="${POSITIONAL[1]}"
VALUE="${POSITIONAL[2]}"

resolve_project

TICKET_FILE=$(find_ticket "$PROJECT_DIR" "$QUERY")
TMP=$(mktemp)

if awk '/^---/{fm++} fm==1 && /^'"$FIELD"':/{found=1} END{exit !found}' "$TICKET_FILE"; then
  awk "
    /^---/ { fm++ }
    fm==1 && /^${FIELD}:/ { print \"${FIELD}: ${VALUE}\"; next }
    { print }
  " "$TICKET_FILE" > "$TMP"
else
  awk "
    /^---/ { fm++ }
    fm==2 && !inserted { print \"${FIELD}: ${VALUE}\"; inserted=1 }
    { print }
  " "$TICKET_FILE" > "$TMP"
fi

mv "$TMP" "$TICKET_FILE"
echo "Updated '$FIELD' → '$VALUE' in $(basename "$TICKET_FILE")  (project: $PROJECT_NAME)"
