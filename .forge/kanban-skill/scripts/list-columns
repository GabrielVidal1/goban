#!/usr/bin/env bash
# list-columns [--project <n>] [--all]
# Lists columns and ticket counts for a project.
# If omitted and only one project exists, uses it automatically.
# With multiple projects and no flag, lists projects. --all shows all projects' columns.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_common.sh"

PROJECT_ARG=""
LIST_ALL=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --project) PROJECT_ARG="$2"; shift 2 ;;
    --all)     LIST_ALL=1; shift ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

# If multiple projects and none specified, list projects summary
if [[ -z "$PROJECT_ARG" && $LIST_ALL -eq 0 ]]; then
  mapfile -t ALL_PROJECTS < <(list_projects)
  if [[ ${#ALL_PROJECTS[@]} -gt 1 ]]; then
    echo "Multiple projects found. Use --project <name> or --all."
    echo ""
    printf "%-25s %s\n" "PROJECT" "COLUMNS"
    printf "%s\n" "$(printf '─%.0s' {1..40})"
    for p in "${ALL_PROJECTS[@]}"; do
      cols=$(find "$KANBAN_DIR/$p" -mindepth 1 -maxdepth 1 -type d ! -name '_*' | wc -l | tr -d ' ')
      printf "%-25s %s\n" "$p" "$cols"
    done
    exit 0
  fi
fi

if [[ $LIST_ALL -eq 1 ]]; then
  mapfile -t ALL_PROJECTS < <(list_projects)
  for p in "${ALL_PROJECTS[@]}"; do
    echo "=== $p ==="
    PROJECT_ARG="$p" resolve_project
    printf "  %-23s %s\n" "COLUMN" "TICKETS"
    printf "  %s\n" "$(printf '─%.0s' {1..35})"
    for col_dir in "$PROJECT_DIR"/*/; do
      [[ -d "$col_dir" ]] || continue
      col_name="$(basename "$col_dir")"
      [[ "$col_name" == _* ]] && continue
      count=$(find "$col_dir" -maxdepth 1 -name "*.md" | wc -l | tr -d ' ')
      printf "  %-23s %s\n" "$col_name" "$count"
    done
    echo ""
  done
  exit 0
fi

resolve_project

echo "Project: $PROJECT_NAME"
printf "%-25s %s\n" "COLUMN" "TICKETS"
printf "%s\n" "$(printf '─%.0s' {1..35})"
for col_dir in "$PROJECT_DIR"/*/; do
  [[ -d "$col_dir" ]] || continue
  col_name="$(basename "$col_dir")"
  [[ "$col_name" == _* ]] && continue
  count=$(find "$col_dir" -maxdepth 1 -name "*.md" | wc -l | tr -d ' ')
  printf "%-25s %s\n" "$col_name" "$count"
done
