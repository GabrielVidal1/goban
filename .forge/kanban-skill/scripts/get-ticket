#!/usr/bin/env bash
# get-ticket <slug> [--project <n>]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_common.sh"

PROJECT_ARG=""
QUERY=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --project) PROJECT_ARG="$2"; shift 2 ;;
    *) QUERY="$1"; shift ;;
  esac
done

if [[ -z "$QUERY" ]]; then
  echo "Usage: get-ticket <slug> [--project <n>]" >&2; exit 1
fi

resolve_project

TICKET_FILE=$(find_ticket "$PROJECT_DIR" "$QUERY")
COL=$(basename "$(dirname "$TICKET_FILE")")
FILE=$(basename "$TICKET_FILE")

echo "=== Ticket: $FILE ==="
echo "Project: $PROJECT_NAME  |  Column: $COL"
echo "Path: $TICKET_FILE"
echo "---"
cat "$TICKET_FILE"
